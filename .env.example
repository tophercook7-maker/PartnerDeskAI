# PartnerDeskAI environment variables — template
#
# Copy this file to .env and fill in your values, OR run the
# interactive wizard which only prompts for missing keys:
#
#   python3 automation/setup_env.py
#
# .env is gitignored — values you put here NEVER get committed.

# --- Core --------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- LinkedIn ----------------------------------------------------------
# CLIENT_ID + CLIENT_SECRET + REDIRECT_URI are used by the in-Hub
# OAuth flow (Control Panel → Connect LinkedIn). ACCESS_TOKEN is then
# written here by the OAuth callback. AUTHOR_URN must be set manually
# (your member URN, e.g. urn:li:person:XXXX).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8787/api/oauth/linkedin/callback
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
LINKEDIN_VERSION=202605

# --- Facebook ----------------------------------------------------------
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- Instagram ---------------------------------------------------------
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Google Business Profile -------------------------------------------
GBP_ACCESS_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
GBP_LANGUAGE_CODE=en-US
GBP_ACTION_TYPE=LEARN_MORE
GBP_ACTION_URL=https://mixedmakershop.com
